{
  "name": "hserve",
  "version": "0.1.3",
  "main": "bin/src/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bagaking/handyServer.git"
  },
  "homepage": "https://github.com/bagaking/handyServer#readme",
  "bugs": {
    "url": "https://github.com/bagaking/handyServer/issues"
  },
  "description": "easy http server",
  "author": "kinghand(kinghand@foxmail.com)",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "tsc": "tsc -d",
    "typecheck": "tsc --noEmit",
    "build": "rimraf ./bin && pnpm run tsc",
    "check:serve-options": "pnpm run build && node scripts/check-serve-options.mjs",
    "check:serve-behavior": "pnpm run build && node scripts/check-serve-behavior.mjs",
    "check:pack": "node scripts/check-pack-contents.mjs",
    "ci": "pnpm run typecheck && pnpm run check:serve-options && pnpm run check:serve-behavior && pnpm run check:pack",
    "prepack": "pnpm run build",
    "serve": "node ./bin/hserve.js"
  },
  "bin": {
    "hserve": "bin/src/index.js"
  },
  "dependencies": {
    "@khgame/turtle": "^0.0.81",
    "@types/koa-mount": "^4.0.0",
    "easy-commander": "^0.0.3",
    "kcors": "^2.2.2",
    "kht": "^0.0.12",
    "koa": "^2.16.4",
    "koa-bodyparser": "^4.2.1",
    "koa-mount": "^4.0.0",
    "koa-router": "^7.4.0",
    "koa-static": "^5.0.0",
    "mongoose": "^6.13.9",
    "routing-controllers": "^0.7.7",
    "typedi": "^0.10.0",
    "reflect-metadata": "^0.1.13",
    "typescript": "^5.4.5",
    "walk": "^2.3.14",
    "yargs": "^12.0.2"
  },
  "devDependencies": {
    "@types/es6-shim": "^0.31.37",
    "@types/kcors": "^2.2.3",
    "@types/koa": "^2.0.49",
    "@types/koa-bodyparser": "^4.3.0",
    "@types/koa-static": "^4.0.1",
    "@types/mongoose": "^5.3.8",
    "@types/walk": "^2.3.0",
    "@types/yargs": "^12.0.1",
    "@types/koa-router": "^7.4.8",
    "@types/node": "10.17.60",
    "rimraf": "^2.6.3"
  },
  "files": [
    "bin"
  ]
}
